**Задание №31**  ----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
**Вопрос:** Написать программу и составить блок-схему для следующей задачи на языке С++. Вывести на экран корни квадратного уравнения.

**Ответ:**  
Квадратное уравнение ax² + bx + c = 0. Вводим a, b, c. Если a = 0 – линейное уравнение. Вычисляем дискриминант D = b² - 4ac. Если D < 0 – корней нет, если D = 0 – один корень, иначе два.

**Код:**  
```cpp
#include <iostream>
#include <cmath>
using namespace std;

int main() {
    double a, b, c;
    cout << "Введите a, b, c: ";
    cin >> a >> b >> c;
    if (a == 0) {
        // линейное уравнение bx + c = 0
        if (b == 0)
            cout << (c == 0 ? "Бесконечно много корней" : "Нет корней") << endl;
        else
            cout << "Один корень: " << -c / b << endl;
    } else {
        double D = b*b - 4*a*c;
        if (D < 0)
            cout << "Нет действительных корней" << endl;
        else if (D == 0)
            cout << "Один корень: " << -b / (2*a) << endl;
        else {
            double sqrtD = sqrt(D);
            cout << "x1 = " << (-b + sqrtD) / (2*a) << endl;
            cout << "x2 = " << (-b - sqrtD) / (2*a) << endl;
        }
    }
    return 0;
}
```

**Блок-схема:** разветвленная: проверка a, затем D.

