**Задание №55**  ----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
**Вопрос:** Ввести с клавиатуры размер массива, выделить необходимый объем памяти для хранения элементов массива и ввести исходные данные. Выполнить задание, результат вывести на экран. Задан массив действительных чисел. Перенести максимальный элемент в нулевую позицию, а минимальный – в последнюю позицию массива. Взаимное расположение остальных элементов не должно изменяться.

**Ответ:**  
Найти индексы максимума и минимума, затем сохранить значения, удалить их из массива и вставить в начало и конец. Или просто поменять местами элементы с соответствующими позициями, но при этом нужно сохранить порядок остальных? Условие: "Взаимное расположение остальных элементов не должно изменяться" – значит, мы не просто меняем местами, а переносим элемент в начало, сдвигая остальные вправо, и аналогично минимум в конец, сдвигая остальные влево. Можно использовать дополнительный массив.

**Код:**  
```cpp
#include <iostream>
#include <vector>
using namespace std;

int main() {
    int n;
    cout << "Введите размер массива: ";
    cin >> n;
    double* arr = new double[n];
    cout << "Введите элементы: ";
    for (int i = 0; i < n; i++) cin >> arr[i];

    int maxIdx = 0, minIdx = 0;
    for (int i = 1; i < n; i++) {
        if (arr[i] > arr[maxIdx]) maxIdx = i;
        if (arr[i] < arr[minIdx]) minIdx = i;
    }

    vector<double> vec(arr, arr + n);
    double maxVal = vec[maxIdx], minVal = vec[minIdx];
    // Удаляем элементы (сначала удаляем тот, индекс которого больше, чтобы не сбить)
    if (maxIdx > minIdx) {
        vec.erase(vec.begin() + maxIdx);
        vec.erase(vec.begin() + minIdx);
    } else {
        vec.erase(vec.begin() + minIdx);
        vec.erase(vec.begin() + maxIdx);
    }
    // Вставляем в начало и конец
    vec.insert(vec.begin(), maxVal);
    vec.push_back(minVal);

    cout << "Результат: ";
    for (double x : vec) cout << x << " ";
    cout << endl;

    delete[] arr;
    return 0;
}
```

